{
  "artifact": "TFII_Tokenized_Fund_Collateral_Admission_Control_001",
  "version": "1.0.0",
  "as_of": "2026-07-16",
  "status": "CONTROLLED_VALIDATED",
  "purpose": "Fail closed before a tokenized fund enters a collateral eligibility query unless its financial object, record architecture and program-specific admission evidence are established at the decision boundary.",
  "source": {
    "public_sample": "output/public_repository/the-token-is-not-the-financial-instrument/release/v1.0/Public Evidence/Tokenized Financial Instrument Integrity - Public Sample - v1.0.json",
    "conformance_test": "data/standards/tfii_finos_cdm_conformance_test_001.json",
    "gdf_report": "https://www.gdf.io/wp-content/uploads/2026/07/6.07.26_Unlocking-Capital-with-U.S-Tokenized-Money-Market-Funds-for-Collateral-Mobility.pdf",
    "finos_revision": "a6ffe777bc12ef3d289579cb3a86d1cbffea63d2"
  },
  "gdf_production_gap": {
    "sandbox_assumptions": [
      "test assets only",
      "no real fund interests transferred",
      "no legal obligations created",
      "one dollar price per token unit",
      "standard haircut across instruments",
      "eligible asset list pre-agreed between pledgor and receiver"
    ],
    "production_requirements": [
      "authoritative ownership record",
      "settlement finality and transfer effectiveness",
      "wallet and transfer controls",
      "reconciliation across token, fund entitlement and collateral records",
      "accepted valuation and haircut treatment",
      "product-level collateral acceptance",
      "default access and liquidation mechanics"
    ],
    "control_response": "TFII establishes a fail-closed integrity precheck before native CDM collateral-criteria matching. Missing mandatory evidence remains UNKNOWN and blocks query execution without declaring the instrument eligible, ineligible, safe or unsafe."
  },
  "control_sequence": [
    {
      "step": 1,
      "name": "identify financial object",
      "pass_condition": "Exact instrument and issuer are source-bound.",
      "fail_closed_result": "HOLD_MISSING_EVIDENCE"
    },
    {
      "step": 2,
      "name": "establish record integrity",
      "pass_condition": "Authoritative record, chain role, transfer boundary, record keeper, processing, correction, reconciliation, wallet controls, valuation, rights and coverage are established.",
      "fail_closed_result": "HOLD_MISSING_EVIDENCE"
    },
    {
      "step": 3,
      "name": "establish program-specific admission evidence",
      "pass_condition": "Governing schedule, receiver acceptance, position, valuation, haircut, concentration, custody/control, default access and freshness are established.",
      "fail_closed_result": "HOLD_MISSING_EVIDENCE"
    },
    {
      "step": 4,
      "name": "invoke CDM eligibility query",
      "pass_condition": "Steps 1 through 3 pass and a complete query can be constructed.",
      "fail_closed_result": "CDM_QUERY_NOT_RUN"
    },
    {
      "step": 5,
      "name": "preserve decision boundary",
      "pass_condition": "The precheck and CDM result are retained as decision inputs subject to independent legal, operational and risk approval.",
      "fail_closed_result": "NO_ADMISSION_DECISION"
    }
  ],
