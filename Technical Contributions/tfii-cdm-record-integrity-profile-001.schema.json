{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://financial-integrity.local/schemas/tfii_cdm_record_integrity_profile_001.schema.json",
  "title": "TFII CDM Record Integrity Profile 001",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact", "version", "as_of", "target_cdm_revision", "source_sample_sha256", "profile_rule", "requirements", "records", "summary", "claim_boundary", "validation"],
  "properties": {
    "artifact": {"const": "TFII_CDM_Record_Integrity_Profile_001"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "as_of": {"type": "string", "format": "date"},
    "target_cdm_revision": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "source_sample_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "profile_rule": {"type": "string", "minLength": 1},
    "requirements": {
      "type": "array",
      "minItems": 17,
      "maxItems": 17,
      "items": {"$ref": "#/$defs/requirement"}
    },
    "records": {
      "type": "array",
      "minItems": 5,
      "items": {"$ref": "#/$defs/record"}
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_count", "native_cdm_result", "combined_profile_result", "record_count", "records_schema_valid", "records_admission_ready", "admission_determinations_made"],
      "properties": {
        "requirement_count": {"const": 17},
        "native_cdm_result": {"const": "PARTIAL"},
        "combined_profile_result": {"const": "PASS"},
        "record_count": {"type": "integer", "minimum": 5},
        "records_schema_valid": {"type": "integer", "minimum": 5},
        "records_admission_ready": {"const": 0},
        "admission_determinations_made": {"const": 0}
      }
    },
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["native_cdm_conformance_overridden", "collateral_eligibility_determined", "private_evidence_inferred", "legal_opinion_provided", "standard_endorsement_claimed"],
      "properties": {
        "native_cdm_conformance_overridden": {"const": false},
        "collateral_eligibility_determined": {"const": false},
        "private_evidence_inferred": {"const": false},
        "legal_opinion_provided": {"const": false},
        "standard_endorsement_claimed": {"const": false}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["json_valid", "schema_valid", "source_hash_verified", "requirement_ids_unique", "all_native_gaps_mapped", "all_records_have_evidence_assertions", "unknowns_preserved", "fail_closed_gate_enforced"],
      "properties": {
        "json_valid": {"const": true},
        "schema_valid": {"const": true},
        "source_hash_verified": {"const": true},
        "requirement_ids_unique": {"const": true},
        "all_native_gaps_mapped": {"const": true},
        "all_records_have_evidence_assertions": {"const": true},
        "unknowns_preserved": {"const": true},
        "fail_closed_gate_enforced": {"const": true}
      }
    }
  },
  "$defs": {
    "result": {"enum": ["PASS", "PARTIAL", "FAIL", "UNKNOWN"]},
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "evidence_state", "source_ids", "source_locator", "confidence", "notes"],
      "properties": {
        "value": {"type": ["string", "number", "boolean", "null"]},
        "evidence_state": {"enum": ["OBSERVATION", "BOUNDED_INTERPRETATION", "DERIVED", "UNKNOWN"]},
        "source_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "source_locator": {"type": ["string", "null"]},
        "confidence": {"enum": ["High", "Medium", "Low", "Unknown"]},
        "notes": {"type": "string"}
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_id", "tfii_field", "native_cdm_status", "profile_field", "combined_status"],
      "properties": {
        "requirement_id": {"type": "string", "pattern": "^TFII-CDM-[0-9]{3}$"},
        "tfii_field": {"type": "string", "minLength": 1},
        "native_cdm_status": {"$ref": "#/$defs/result"},
        "profile_field": {"type": "string", "minLength": 1},
        "combined_status": {"const": "PASS"}
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_id", "instrument_name", "architecture_class", "financial_object", "record_integrity", "evidence_assertions", "coverage", "collateral_gate"],
      "properties": {
        "record_id": {"type": "string", "pattern": "^FET-TFII-[0-9]{3}$"},
        "instrument_name": {"type": "string", "minLength": 1},
        "architecture_class": {"type": "string", "minLength": 1},
        "financial_object": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cdm_asset_class", "security_type", "source_record_id"],
          "properties": {
            "cdm_asset_class": {"const": "Security"},
            "security_type": {"const": "FundShare"},
            "source_record_id": {"type": "string", "pattern": "^FET-TFII-[0-9]{3}$"}
          }
        },
        "record_integrity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["record_keeper", "authoritative_record", "token_role", "ownership_effective_event", "valuation_authority", "correction_authority", "correction_lineage", "reconciliation", "wallet_eligibility", "rights_state"],
          "properties": {
            "record_keeper": {"$ref": "#/$defs/assertion"},
            "authoritative_record": {"$ref": "#/$defs/assertion"},
            "token_role": {"$ref": "#/$defs/assertion"},
            "ownership_effective_event": {"$ref": "#/$defs/assertion"},
            "valuation_authority": {"$ref": "#/$defs/assertion"},
            "correction_authority": {"$ref": "#/$defs/assertion"},
            "correction_lineage": {"$ref": "#/$defs/assertion"},
            "reconciliation": {"$ref": "#/$defs/assertion"},
            "wallet_eligibility": {"$ref": "#/$defs/assertion"},
            "rights_state": {"$ref": "#/$defs/assertion"}
          }
        },
        "evidence_assertions": {
          "type": "object",
          "minProperties": 8,
          "additionalProperties": {"$ref": "#/$defs/assertion"}
        },
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["observation_boundary", "source_scope", "freshness_state", "unknowns"],
          "properties": {
            "observation_boundary": {"type": "string", "format": "date"},
            "source_scope": {"type": "string", "minLength": 1},
            "freshness_state": {"const": "POINT_IN_TIME_ONLY"},
            "unknowns": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
          }
        },
        "collateral_gate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["architecture_integrity_state", "program_evidence_state", "missing_program_fields", "cdm_eligibility_query_permitted", "determination"],
          "properties": {
            "architecture_integrity_state": {"const": "PARTIAL"},
            "program_evidence_state": {"const": "UNKNOWN"},
            "missing_program_fields": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
            "cdm_eligibility_query_permitted": {"const": false},
            "determination": {"const": "UNKNOWN"}
          }
        }
      }
    }
  }
}
