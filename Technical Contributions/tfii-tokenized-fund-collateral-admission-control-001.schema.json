{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://financial-integrity.local/schemas/tfii_tokenized_fund_collateral_admission_control_001.schema.json",
  "title": "TFII Tokenized-Fund Collateral Admission Control 001",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact",
    "version",
    "as_of",
    "status",
    "purpose",
    "source",
    "gdf_production_gap",
    "control_sequence",
    "requirement_catalog",
    "instrument_results",
    "aggregate",
    "external_determination",
    "claim_boundary",
    "validation"
  ],
  "properties": {
    "artifact": {"const": "TFII_Tokenized_Fund_Collateral_Admission_Control_001"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "as_of": {"type": "string", "format": "date"},
    "status": {"enum": ["CONTROLLED_DRAFT", "CONTROLLED_VALIDATED", "PUBLIC_TECHNICAL_CONTRIBUTION"]},
    "purpose": {"type": "string", "minLength": 1},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public_sample", "conformance_test", "gdf_report", "finos_revision"],
      "properties": {
        "public_sample": {"type": "string", "minLength": 1},
        "conformance_test": {"type": "string", "minLength": 1},
        "gdf_report": {"type": "string", "format": "uri"},
        "finos_revision": {"type": "string", "pattern": "^[a-f0-9]{40}$"}
      }
    },
    "gdf_production_gap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sandbox_assumptions", "production_requirements", "control_response"],
      "properties": {
        "sandbox_assumptions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "production_requirements": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "control_response": {"type": "string", "minLength": 1}
      }
    },
    "control_sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "name", "pass_condition", "fail_closed_result"],
        "properties": {
          "step": {"type": "integer", "minimum": 1},
          "name": {"type": "string", "minLength": 1},
          "pass_condition": {"type": "string", "minLength": 1},
          "fail_closed_result": {"type": "string", "minLength": 1}
        }
      }
    },
    "requirement_catalog": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/requirement"}
    },
    "instrument_results": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/instrumentResult"}
    },
    "aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instrument_count", "architecture_precheck_complete", "architecture_precheck_partial", "architecture_precheck_unknown", "ready_for_cdm_eligibility_query", "held_for_missing_evidence", "cdm_queries_run", "admission_decisions_made", "determination_counts"],
      "properties": {
        "instrument_count": {"type": "integer", "minimum": 1},
        "architecture_precheck_complete": {"type": "integer", "minimum": 0},
        "architecture_precheck_partial": {"type": "integer", "minimum": 0},
        "architecture_precheck_unknown": {"type": "integer", "minimum": 0},
        "ready_for_cdm_eligibility_query": {"type": "integer", "minimum": 0},
        "held_for_missing_evidence": {"type": "integer", "minimum": 0},
        "cdm_queries_run": {"type": "integer", "minimum": 0},
        "admission_decisions_made": {"type": "integer", "minimum": 0},
        "determination_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["PASS", "PARTIAL", "FAIL", "UNKNOWN"],
          "properties": {
            "PASS": {"type": "integer", "minimum": 0},
            "PARTIAL": {"type": "integer", "minimum": 0},
            "FAIL": {"type": "integer", "minimum": 0},
            "UNKNOWN": {"type": "integer", "minimum": 0}
          }
        }
      }
    },
    "external_determination": {"$ref": "#/$defs/result"},
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["legal_opinion_provided", "instrument_declared_eligible", "instrument_declared_ineligible", "risk_score_produced", "investment_recommendation_provided", "automated_execution_authorized"],
      "properties": {
        "legal_opinion_provided": {"const": false},
        "instrument_declared_eligible": {"const": false},
        "instrument_declared_ineligible": {"const": false},
        "risk_score_produced": {"const": false},
        "investment_recommendation_provided": {"const": false},
        "automated_execution_authorized": {"const": false}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["json_valid", "schema_valid", "requirement_ids_unique", "record_ids_match_public_sample", "all_mandatory_unknowns_fail_closed", "no_cdm_query_ran_before_precheck", "no_admission_decision_produced", "aggregate_recomputed", "claim_boundary_passed"],
      "properties": {
        "json_valid": {"const": true},
        "schema_valid": {"const": true},
        "requirement_ids_unique": {"const": true},
        "record_ids_match_public_sample": {"const": true},
        "all_mandatory_unknowns_fail_closed": {"const": true},
        "no_cdm_query_ran_before_precheck": {"const": true},
        "no_admission_decision_produced": {"const": true},
        "aggregate_recomputed": {"const": true},
        "claim_boundary_passed": {"const": true}
      }
    }
  },
  "$defs": {
    "result": {"enum": ["PASS", "PARTIAL", "FAIL", "UNKNOWN"]},
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_id", "layer", "field", "question", "mandatory", "public_sample_key", "unknown_effect"],
      "properties": {
        "requirement_id": {"type": "string", "pattern": "^TFII-AC-[0-9]{3}$"},
        "layer": {"enum": ["ARCHITECTURE_INTEGRITY", "PROGRAM_SPECIFIC_ADMISSION"]},
        "field": {"type": "string", "minLength": 1},
        "question": {"type": "string", "minLength": 1},
        "mandatory": {"type": "boolean"},
        "public_sample_key": {"type": ["string", "null"]},
        "unknown_effect": {"const": "HOLD_MISSING_EVIDENCE"}
      }
    },
    "requirementResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_id", "status", "source_locator", "note"],
      "properties": {
        "requirement_id": {"type": "string", "pattern": "^TFII-AC-[0-9]{3}$"},
        "status": {"$ref": "#/$defs/result"},
        "source_locator": {"type": "string", "minLength": 1},
        "note": {"type": "string", "minLength": 1}
      }
    },
    "instrumentResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_id", "instrument_name", "architecture_class", "architecture_results", "program_results", "architecture_precheck", "precheck_state", "cdm_eligibility_query_state", "determination", "unknowns", "not_an_eligibility_decision"],
      "properties": {
        "record_id": {"type": "string", "pattern": "^FET-TFII-[0-9]{3}$"},
        "instrument_name": {"type": "string", "minLength": 1},
        "architecture_class": {"type": "string", "minLength": 1},
        "architecture_results": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/requirementResult"}},
        "program_results": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/requirementResult"}},
        "architecture_precheck": {"$ref": "#/$defs/result"},
        "precheck_state": {"enum": ["READY_FOR_CDM_ELIGIBILITY_QUERY", "HOLD_MISSING_EVIDENCE", "HOLD_CONFLICTING_EVIDENCE"]},
        "cdm_eligibility_query_state": {"enum": ["NOT_RUN", "RUN"]},
        "determination": {"$ref": "#/$defs/result"},
        "unknowns": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "not_an_eligibility_decision": {"const": true}
      }
    }
  }
}
