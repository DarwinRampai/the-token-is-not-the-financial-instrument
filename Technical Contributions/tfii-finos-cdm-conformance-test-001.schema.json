{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://financial-integrity.local/schemas/tfii_finos_cdm_conformance_test_001.schema.json",
  "title": "TFII to FINOS CDM Conformance Test 001",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact",
    "version",
    "as_of",
    "status",
    "test_rule",
    "target_standard",
    "tfii_source",
    "requirements",
    "test_vectors",
    "summary",
    "claim_boundary",
    "validation"
  ],
  "properties": {
    "artifact": {"const": "TFII_to_FINOS_CDM_Conformance_Test_001"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "as_of": {"type": "string", "format": "date"},
    "status": {"enum": ["CONTROLLED_DRAFT", "CONTROLLED_VALIDATED", "PUBLIC_TECHNICAL_CONTRIBUTION"]},
    "test_rule": {"type": "string", "minLength": 1},
    "target_standard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "repository", "revision", "revision_date", "inspected_paths"],
      "properties": {
        "name": {"const": "FINOS Common Domain Model"},
        "repository": {"const": "https://github.com/finos/common-domain-model"},
        "revision": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
        "revision_date": {"type": "string", "format": "date"},
        "inspected_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "tfii_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["methodology", "public_sample", "public_repository", "doi", "record_ids"],
      "properties": {
        "methodology": {"type": "string", "minLength": 1},
        "public_sample": {"type": "string", "minLength": 1},
        "public_repository": {"type": "string", "format": "uri"},
        "doi": {"type": "string", "format": "uri"},
        "record_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^FET-TFII-[0-9]{3}$"}
        }
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/requirement"}
    },
    "test_vectors": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/testVector"}
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_count", "result_counts", "record_count", "overall_result", "public_technical_contribution_permitted"],
      "properties": {
        "requirement_count": {"type": "integer", "minimum": 1},
        "result_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["PASS", "PARTIAL", "FAIL", "UNKNOWN"],
          "properties": {
            "PASS": {"type": "integer", "minimum": 0},
            "PARTIAL": {"type": "integer", "minimum": 0},
            "FAIL": {"type": "integer", "minimum": 0},
            "UNKNOWN": {"type": "integer", "minimum": 0}
          }
        },
        "record_count": {"type": "integer", "minimum": 1},
        "overall_result": {"$ref": "#/$defs/result"},
        "public_technical_contribution_permitted": {"type": "boolean"}
      }
    },
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cdm_defect_alleged", "legal_opinion_provided", "collateral_eligibility_determined", "standard_endorsement_claimed"],
      "properties": {
        "cdm_defect_alleged": {"const": false},
        "legal_opinion_provided": {"const": false},
        "collateral_eligibility_determined": {"const": false},
        "standard_endorsement_claimed": {"const": false}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["json_valid", "schema_valid", "requirement_ids_unique", "test_vectors_match_public_sample", "result_counts_recomputed", "overall_result_recomputed", "claim_boundary_passed"],
      "properties": {
        "json_valid": {"const": true},
        "schema_valid": {"const": true},
        "requirement_ids_unique": {"const": true},
        "test_vectors_match_public_sample": {"const": true},
        "result_counts_recomputed": {"const": true},
        "overall_result_recomputed": {"const": true},
        "claim_boundary_passed": {"const": true}
      }
    }
  },
  "$defs": {
    "result": {"enum": ["PASS", "PARTIAL", "FAIL", "UNKNOWN"]},
    "confidence": {"enum": ["High", "Medium", "Low", "Unknown"]},
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_id", "tfii_field", "financial_question", "materiality", "cdm_candidate_paths", "native_capability", "extension_or_control_needed", "status", "evidence"],
      "properties": {
        "requirement_id": {"type": "string", "pattern": "^TFII-CDM-[0-9]{3}$"},
        "tfii_field": {"type": "string", "minLength": 1},
        "financial_question": {"type": "string", "minLength": 1},
        "materiality": {"enum": ["CORE", "SUPPORTING"]},
        "cdm_candidate_paths": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "native_capability": {"type": "string", "minLength": 1},
        "extension_or_control_needed": {"type": "string", "minLength": 1},
        "status": {"$ref": "#/$defs/result"},
        "evidence": {"$ref": "#/$defs/evidence"}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_class", "source_uri", "source_revision", "source_locator", "derivation_status", "confidence"],
      "properties": {
        "source_class": {"enum": ["FINOS_CDM_SOURCE", "FINOS_CDM_GOVERNANCE", "TFII_PUBLIC_RECORD", "GDF_ISDA_REPORT"]},
        "source_uri": {"type": "string", "format": "uri"},
        "source_revision": {"type": "string", "minLength": 1},
        "source_locator": {"type": "string", "minLength": 1},
        "derivation_status": {"enum": ["OBSERVATION", "BOUNDED_INTERPRETATION", "UNKNOWN"]},
        "confidence": {"$ref": "#/$defs/confidence"}
      }
    },
    "testVector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_id", "instrument_name", "architecture_class", "transfer_boundary_class", "source_evidence_state", "expected_distinctions", "failed_requirement_ids", "source_unknowns", "result"],
      "properties": {
        "record_id": {"type": "string", "pattern": "^FET-TFII-[0-9]{3}$"},
        "instrument_name": {"type": "string", "minLength": 1},
        "architecture_class": {"type": "string", "minLength": 1},
        "transfer_boundary_class": {"enum": ["BLOCKCHAIN_CONFIRMATION", "OFFCHAIN_REGISTER_UPDATE", "BLOCKCHAIN_THEN_BOOK_ENTRY", "UNKNOWN"]},
        "source_evidence_state": {"enum": ["COMPLETE", "PARTIAL"]},
        "expected_distinctions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "failed_requirement_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^TFII-CDM-[0-9]{3}$"}
        },
        "source_unknowns": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "result": {"$ref": "#/$defs/result"}
      }
    }
  }
}
